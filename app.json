{
  "expo": {
    "name": "DoaFacil",
    "slug": "projeto_mari_cest-Basica",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.jpg",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.guilhermepomacercena.projeto_mari_cestBasica",
      "infoPlist": {
        "NSCameraUsageDescription": "Precisamos acessar sua câmera para anexar comprovante PIX",
        "NSPhotoLibraryUsageDescription": "Precisamos acessar sua galeria para anexar comprovante PIX",
        "NSLocationWhenInUseUsageDescription": "Precisamos da sua localização para sugerir endereço de entrega"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.jpg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.guilhermepomacercena.projeto_mari_cestBasica"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ee236f7d-391c-4d96-a6de-09c015dbd45c"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-image-picker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Precisamos da sua localização para sugerir endereço de entrega"
        }
      ]
    ]
  }
}
